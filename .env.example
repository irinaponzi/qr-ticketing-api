# =============================================================================
# EntradasQR - Environment Variables
# =============================================================================
# Copy this file to .env and modify as needed.
# Variables are prefixed per service to avoid collisions (PORT, DB_PORT, etc.
# differ between Ticket API and Validator API). The Makefile maps these to the
# generic names each Go service expects via envconfig.

# --- Shared ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
HMAC_SECRET=change-me-in-production

# --- Ticket API ---
TICKET_PORT=8080
TICKET_DB_HOST=localhost
TICKET_DB_PORT=3306
TICKET_DB_USER=root
TICKET_DB_PASSWORD=root
TICKET_DB_NAME=tickets_db

# --- Redis ---
REDIS_PORT=6379
REDISINSIGHT_PORT=5540

# --- Validator API ---
VALIDATOR_PORT=8081
VALIDATOR_REDIS_HOST=localhost
VALIDATOR_TICKET_SERVICE_URL=http://localhost:8080

# --- QR Worker ---
# SMTP configuration for sending ticket emails with QR codes.
#
# Option A — MailHog (local dev, emails captured at http://localhost:8025):
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_FROM=tickets@entradasqr.local
#   SMTP_USER=
#   SMTP_PASSWORD=
#
# Option B — Gmail (real emails, requires App Password):
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Paste it in SMTP_PASSWORD below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=YOUR_GMAIL@gmail.com
SMTP_USER=YOUR_GMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
QR_SIZE=256
MAILHOG_UI_PORT=8025

# --- Authentication (AWS Cognito) ---
# Both Ticket API and Validator API read these variables.
# Set COGNITO_USER_POOL_ID to your actual User Pool ID (e.g. us-east-1_AbCdEfGhI).
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
